-- ── 3. NPCs ───────────────────────────────────────────────────

safe("NPCS", function()
    titulo("NPCs / MOBS")

    local npcs        = {}
    local grupos      = {}
    local ordemGrupos = {}

    local function scanNPCs(parent, depth)
        if depth > 8 then return end
        local filhos
        local ok, err = pcall(function() filhos = parent:GetChildren() end)
        if not ok or not filhos then return end

        for _, obj in ipairs(filhos) do
            safe("NPC_OBJ_" .. tostring(obj.Name), function()
                if obj == lp.Character then return end

                local hum = obj:FindFirstChildOfClass("Humanoid")
                if not hum then
                    scanNPCs(obj, depth + 1)
                    return
                end

                -- posicao
                local pos  = "N/A"
                local root = obj:FindFirstChild("HumanoidRootPart")
                          or obj:FindFirstChild("Torso")
                          or obj:FindFirstChild("UpperTorso")
                if not root then
                    -- pega qualquer BasePart como fallback
                    for _, p2 in ipairs(obj:GetChildren()) do
                        if p2:IsA("BasePart") then root = p2 break end
                    end
                end
                if root then
                    local cf = root.CFrame.Position
                    pos = string.format("%.1f,%.1f,%.1f", cf.X, cf.Y, cf.Z)
                end

                -- valores internos (level, tipo, etc) — so 1 nivel pra nao travar
                local vals = {}
                safe("NPC_VALS_" .. obj.Name, function()
                    for _, v in ipairs(obj:GetChildren()) do
                        if v:IsA("ValueBase") then
                            table.insert(vals, v.Name .. "=" .. tostring(v.Value))
                        end
                        -- 1 nivel a mais
                        for _, v2 in ipairs(v:GetChildren()) do
                            if v2:IsA("ValueBase") then
                                table.insert(vals, v.Name .. "." .. v2.Name .. "=" .. tostring(v2.Value))
                            end
                        end
                    end
                end)

                local hp, maxhp, speed = 0, 0, 0
                safe("NPC_STATS_" .. obj.Name, function()
                    hp    = hum.Health
                    maxhp = hum.MaxHealth
                    speed = hum.WalkSpeed
                end)

                table.insert(npcs, {
                    nome  = obj.Name,
                    path  = obj:GetFullName(),
                    pos   = pos,
                    hp    = hp,
                    maxhp = maxhp,
                    speed = speed,
                    vals  = vals,
                })

                -- nao desce dentro do NPC
            end)
        end
    end

    scanNPCs(workspace, 0)

    -- agrupa
    for _, n in ipairs(npcs) do
        if not grupos[n.nome] then
            grupos[n.nome] = { count = 0, exemplo = n }
            table.insert(ordemGrupos, n.nome)
        end
        grupos[n.nome].count = grupos[n.nome].count + 1
    end

    if #ordemGrupos == 0 then
        p("  nenhum NPC encontrado (pode estar em pasta protegida)")
    end

    for _, nome in ipairs(ordemGrupos) do
        local g = grupos[nome]
        local e = g.exemplo
        sub(nome .. "  x" .. g.count)
        p("  PATH",  e.path)
        p("  POS",   e.pos)
        p("  HP",    string.format("%.0f/%.0f", e.hp, e.maxhp))
        p("  SPEED", e.speed)
        if #e.vals > 0 then p("  VALS", table.concat(e.vals, "  ")) end
    end

    -- nomes unicos pra copiar direto no farm
    titulo("NOMES UNICOS DE NPCs")
    local seen = {}
    for _, n in ipairs(npcs) do
        if not seen[n.nome] then
            seen[n.nome] = true
            p('  "' .. n.nome .. '"')
        end
    end
end)

-- ── 4. REMOTES ────────────────────────────────────────────────

safe("REMOTES", function()
    titulo("REMOTE EVENTS / FUNCTIONS")

    local function listarRemotes(parent, depth)
        if depth > 6 then return end
        local filhos
        local ok = pcall(function() filhos = parent:GetChildren() end)
        if not ok or not filhos then return end
        for _, obj in ipairs(filhos) do
            safe("REMOTE_" .. obj.Name, function()
                local t = obj.ClassName
                if t == "RemoteEvent" or t == "RemoteFunction"
                or t == "BindableEvent" or t == "BindableFunction" then
                    p("  " .. t, obj:GetFullName())
                end
                listarRemotes(obj, depth + 1)
            end)
        end
    end

    sub("ReplicatedStorage")
    listarRemotes(RS, 0)
    sub("Workspace")
    listarRemotes(workspace, 0)
end)

-- ── 5. SPAWNS & TELEPORTS ─────────────────────────────────────

safe("SPAWNS", function()
    titulo("SPAWNS & TELEPORTS")
    local palavras = {"teleport","warp","portal","door","enter","island","sea","boss"}

    local function scan(parent, depth)
        if depth > 5 then return end
        local filhos
        local ok = pcall(function() filhos = parent:GetChildren() end)
        if not ok or not filhos then return end
        for _, obj in ipairs(filhos) do
            safe("SPAWN_" .. obj.Name, function()
                if obj.ClassName == "SpawnLocation" then
                    local pos = obj.Position
                    p("  SPAWN", obj.Name, string.format("%.1f,%.1f,%.1f", pos.X, pos.Y, pos.Z), obj:GetFullName())
                end
                if obj:IsA("BasePart") then
                    local nome = obj.Name:lower()
                    for _, kw in ipairs(palavras) do
                        if nome:find(kw) then
                            local pos = obj.Position
                            p("  PART", obj.Name, string.format("%.1f,%.1f,%.1f", pos.X, pos.Y, pos.Z), obj:GetFullName())
                            break
                        end
                    end
                end
                scan(obj, depth + 1)
            end)
        end
    end
    scan(workspace, 0)
end)

