safe("TOOLS", function()
    titulo("TOOLS / WEAPONS")
    local function listarTools(parent)
        local filhos
        local ok = pcall(function() filhos = parent:GetChildren() end)
        if not ok or not filhos then return end
        for _, t in ipairs(filhos) do
            safe("TOOL_" .. t.Name, function()
                if t:IsA("Tool") then
                    local remotes = {}
                    for _, r in ipairs(t:GetDescendants()) do
                        if r:IsA("RemoteEvent") or r:IsA("RemoteFunction") then
                            table.insert(remotes, r.Name)
                        end
                    end
                    p("  " .. t.Name, "remotes=[" .. table.concat(remotes, ",") .. "]")
                end
            end)
        end
    end
    safe("BACKPACK", function() listarTools(lp.Backpack) end)
    if lp.Character then listarTools(lp.Character) end
end)

