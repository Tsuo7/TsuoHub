local function tryClipboard()
    local metodos = {
        function() setclipboard(texto) end,
        function() toclipboard(texto) end,
        function() Clipboard.set(texto) end,
        function() syn.clipboard.set(texto) end,
    }
    for _, fn in ipairs(metodos) do
        if pcall(fn) then return true end
    end
    return false
end

