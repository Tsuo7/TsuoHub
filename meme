local output = {}
local erros  = {}

-- p() aceita qualquer tipo sem explodir
local function p(...)
    local partes = {}
    for i = 1, select("#", ...) do
        local v = select(i, ...)
        table.insert(partes, tostring(v ~= nil and v or "nil"))
    end
    local linha = table.concat(partes, " | ")
    print(linha)
    table.insert(output, linha)
end

local function titulo(t)
    local sep = string.rep("=", 54)
    p(""); p(sep); p("  " .. t); p(sep)
end

local function sub(t)
    p(""); p("  >> " .. t)
end

local function safe(tag, fn)
    local ok, err = pcall(fn)
    if not ok then
        local msg = "[ERRO:" .. tag .. "] " .. tostring(err)
        table.insert(erros, msg)
        print(msg)
    end
end

